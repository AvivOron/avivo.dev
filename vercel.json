{
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://finance-hub-umber.vercel.app/finance-hub/api/:path*"
    },
    {
      "source": "/finance-hub",
      "destination": "https://finance-hub-umber.vercel.app/finance-hub"
    },
    {
      "source": "/finance-hub/:path*",
      "destination": "https://finance-hub-umber.vercel.app/finance-hub/:path*"
    },
    {
      "source": "/guess-who",
      "destination": "https://guess-who-sigma.vercel.app/guess-who"
    },
    {
      "source": "/guess-who/:path*",
      "destination": "https://guess-who-sigma.vercel.app/guess-who/:path*"
    }
  ]
}
